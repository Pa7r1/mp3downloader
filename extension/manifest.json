{
  "manifest_version": 3,
  "name": "YDL — YouTube Downloader",
  "version": "1.0.0",
  "description": "Descargá audio y video de YouTube con un clic",
  "permissions": ["activeTab", "nativeMessaging", "storage", "downloads"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
